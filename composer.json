{
  "name": "emergencyforge/intrarp",
  "description": "Das Intranet für deine Fraktionen (Feuerwehr, Rettungsdienst). Allround-Fraktionsverwaltung und das Open-Source & kostenlos! ",
  "license": "proprietary",
  "require": {
    "vlucas/phpdotenv": "^5.6",
    "enyo/dropzone": "^5.9",
    "league/oauth2-client": "^2.8",
    "twig/twig": "^3.14",
    "dompdf/dompdf": "^3.1",
    "erusev/parsedown": "^1.7",
    "monolog/monolog": "^3.10",
    "robmorgan/phinx": "^0.16",
    "php-di/php-di": "^7.0",
    "illuminate/database": "^11.0",
    "illuminate/events": "^11.0",
    "respect/validation": "^2.3",
    "nikic/fast-route": "1.3",
    "illuminate/queue": "11.0",
    "symfony/console": "7.0.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": false,
    "apcu-autoloader": true
  },
  "scripts": {
    "db:migrate": "@php tools/db-migrate.php",
    "db:status": "@php vendor/bin/phinx status -e production -c phinx.php",
    "intra": "@php cli/intra.php",
    "queue:work": "@php cli/intra.php queue:work",
    "queue:failed:list": "@php cli/intra.php queue:failed:list",
    "telemetry:send": "@php cli/intra.php telemetry:send",
    "test": "@php vendor/bin/phpunit",
    "test:unit": "@php vendor/bin/phpunit --testsuite Unit",
    "test:integration": "@php vendor/bin/phpunit --testsuite Integration",
    "post-install-cmd": [
      "@db:migrate"
    ],
    "post-update-cmd": [
      "@db:migrate"
    ]
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5"
  }
}
