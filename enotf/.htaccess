<IfModule mod_headers.c>
    # Prüfe User-Agent
    SetEnvIf User-Agent "CitizenFX" FIVEM
    Header always unset Content-Security-Policy env=FIVEM
    Header always unset X-Frame-Options env=FIVEM
    Header set Content-Security-Policy "frame-ancestors 'self' https://*" env=!FIVEM
</IfModule>

# Clean URLs fuer dynamisches Protokollsystem
# /enotf/protokoll/{enr}/{section} -> section.php?enr=...&section=...
# Nur matchen wenn KEIN Punkt im Pfad (keine .php Dateien abfangen)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^protokoll/([^/.]+)/([^/.]+)/?$ protokoll/section.php?enr=$1&section=$2 [QSA,L]
</IfModule>
