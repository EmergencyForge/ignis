#1 ---- Prevent listing

IndexIgnore *
Options -Indexes

#1b ---- Security: Block sensitive files
#
# Apache 2.4 verwendet `Require all denied`. Falls noch Apache 2.2 im Einsatz
# ist, greift `Order/Deny` als Fallback. Beide Direktiven nebeneinander sind
# erlaubt — die nicht passende wird ignoriert.

# Block alle .env-Varianten (.env, .env.test, .env.local, .env.production, ...)
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block Phinx-Config (wird nur von CLI gelesen, nicht via HTTP)
<Files "phinx.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Block Composer/Build-Konfigurationen
<FilesMatch "^(composer\.(json|lock)|package\.json|package-lock\.json|phpstan\.neon|phpunit\.xml(\.dist)?)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block interne Verzeichnisse komplett vor direktem Web-Zugriff.
# Diese Ordner enthalten Quellcode, CLI-Scripts, Tools und Legacy-Code,
# die niemals direkt über HTTP erreichbar sein sollen — sie werden
# entweder aus anderen Scripts includiert oder nur über die CLI aufgerufen.
RewriteRule ^src/ - [F,L]
RewriteRule ^cli/ - [F,L]
RewriteRule ^tools/ - [F,L]
RewriteRule ^tests/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^docker/ - [F,L]
RewriteRule ^routes/ - [F,L]
RewriteRule ^\.github/ - [F,L]

# cron/ bleibt erreichbar, weil HTTP-triggerbare Cron-Endpoints dort liegen
# (queue-worker-cron.php, telemetry-cron.php). Diese prüfen API-Key intern
# und sind die einzigen expliziten Einsprungspunkte — andere Dateien dort
# werden nicht erstellt, aber Legacy-Datei-Schutz hängt an den Script-Checks.

#2 ---- Without extension

Options +MultiViews

# DirectorySlash Off verhindert, dass Apache automatisch von /foo nach /foo/
# redirected, wenn /foo zufaellig ein leeres Legacy-Verzeichnis ist (z.B. nach
# einem unvollstaendigen Deploy). Ohne diese Direktive entstehen Redirect-Loops
# auf Controller-served Routes wie /kalender und /manv, sobald deren alte
# Modul-Ordner auf dem Webspace stehen geblieben sind.
DirectorySlash Off

#3 ---- Rewrites

RewriteEngine On

# ============================================================
# Router Fallback
#
# Greift, wenn der Request weder auf eine echte Datei noch auf
# ein bewusst legacy-gehaltenes Verzeichnis zeigt, und leitet
# ihn an den Single-Entry-Point `public/index.php` weiter, wo
# `App\Http\Router` das Matching übernimmt. eNOTF-Clean-URLs
# (`/enotf/p/{enr}/...`) sind direkt im Router registriert.
#
# Whitelist statt `!-d`: nur explizit aufgelistete Verzeichnisse
# behalten ihren eigenen DirectoryIndex (Assets, Vendor-Dirs,
# wissensdb/, dokumente/). Alles andere geht durch den Router,
# auch wenn ein gleichnamiger Ordner stehen geblieben ist —
# das verhindert Redirect-Loops nach unvollstaendigen Deploys.
#
# MultiViews (+MultiViews oben) resolvt zusätzlich `/foo` zu
# `/foo.php` BEVOR die Rewrites laufen, sodass Extension-lose
# Legacy-URLs weiterhin direkt funktionieren.
# ============================================================

RewriteCond %{REQUEST_URI} !^/(assets|public|vendor|node_modules|storage|uploads|cron|wissensdb|dokumente|auth)(/|$)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ public/index.php [L,QSA]
