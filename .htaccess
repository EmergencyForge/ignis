#1 ---- Prevent listing

IndexIgnore *
Options -Indexes

#1b ---- Security: Block sensitive files
#
# Apache 2.4 verwendet `Require all denied`. Falls noch Apache 2.2 im Einsatz
# ist, greift `Order/Deny` als Fallback. Beide Direktiven nebeneinander sind
# erlaubt — die nicht passende wird ignoriert.

# Block alle .env-Varianten (.env, .env.test, .env.local, .env.production, ...)
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block Phinx-Config (wird nur von CLI gelesen, nicht via HTTP)
<Files "phinx.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Block Composer/Build-Konfigurationen
<FilesMatch "^(composer\.(json|lock)|package\.json|package-lock\.json|phpstan\.neon|phpunit\.xml(\.dist)?)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block interne Verzeichnisse komplett vor direktem Web-Zugriff.
# Diese Ordner enthalten Quellcode, CLI-Scripts, Tools und Legacy-Code,
# die niemals direkt über HTTP erreichbar sein sollen — sie werden
# entweder aus anderen Scripts includiert oder nur über die CLI aufgerufen.
RewriteRule ^src/ - [F,L]
RewriteRule ^cli/ - [F,L]
RewriteRule ^tools/ - [F,L]
RewriteRule ^tests/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^docker/ - [F,L]
RewriteRule ^routes/ - [F,L]
RewriteRule ^\.github/ - [F,L]

# cron/ bleibt erreichbar, weil HTTP-triggerbare Cron-Endpoints dort liegen
# (queue-worker-cron.php, telemetry-cron.php). Diese prüfen API-Key intern
# und sind die einzigen expliziten Einsprungspunkte — andere Dateien dort
# werden nicht erstellt, aber Legacy-Datei-Schutz hängt an den Script-Checks.

#2 ---- Without extension

Options +MultiViews

#3 ---- Rewrites

RewriteEngine On

# ============================================================
# eNOTF Clean URLs
# Aktiv auf allen Umgebungen (damit Clean-URLs immer funktionieren).
# Die URL-Generierung (clean vs. legacy) steuert EnotfUrl.php
# per APP_ENV.
# ============================================================

# --- Top-Level-Seiten (.php-Erweiterung entfernen) ---
# MultiViews erledigt das bereits, diese Regeln dienen als expliziter Fallback
RewriteRule ^enotf/(login|overview|create|lockscreen|loggedout|fahrzeuginfo|hospital-availability)$ enotf/$1.php [L,QSA]

# --- Protokoll: /enotf/p/{enr} ---
RewriteRule ^enotf/p/([\w._-]+)/?$ enotf/protokoll/index.php?enr=$1 [L,QSA]

# --- Protokoll: /enotf/p/{enr}/{section} (Sektions-Index) ---
RewriteRule ^enotf/p/([\w._-]+)/([\w-]+)/?$ enotf/protokoll/$2/index.php?enr=$1 [L,QSA]

# --- Protokoll: /enotf/p/{enr}/{section}/{page_or_subsection} ---
# Sektionen mit Unterverzeichnissen (erstbefund, massnahmen): 3. Segment = Verzeichnis
RewriteRule ^enotf/p/([\w._-]+)/(erstbefund|massnahmen)/([\w-]+)/?$ enotf/protokoll/$2/$3/index.php?enr=$1 [L,QSA]
# Sektionen mit .php-Dateien (diagnose, anamnese, rettdaten, verlauf, abschluss): 3. Segment = Datei
RewriteRule ^enotf/p/([\w._-]+)/(diagnose|anamnese|rettdaten|verlauf|abschluss)/([\w_-]+)/?$ enotf/protokoll/$2/$3.php?enr=$1 [L,QSA]

# --- Protokoll: /enotf/p/{enr}/{section}/{subsection}/{page} (tiefe Seiten) ---
RewriteRule ^enotf/p/([\w._-]+)/([\w-]+)/([\w-]+)/([\w_-]+)/?$ enotf/protokoll/$2/$3/$4.php?enr=$1 [L,QSA]

# --- Print: /enotf/print/{enr} ---
RewriteRule ^enotf/print/([\w._-]+)/?$ enotf/print/index.php?enr=$1 [L,QSA]

# --- Admin: /enotf/admin → list.php ---
RewriteRule ^enotf/admin/?$ enotf/admin/list.php [L,QSA]

# ============================================================
# Router Fallback (Phase 3.1)
#
# Greift NUR, wenn der Request weder auf eine echte Datei noch
# ein echtes Verzeichnis zeigt, UND weiter oben keine eNOTF-Clean-
# URL-Regel zugeschlagen hat. Leitet in dem Fall an den Single-
# Entry-Point `public/index.php` weiter, wo der `App\Http\Router`
# das Matching übernimmt.
#
# Bestehende Modul-Files (benutzer/list.php, einsatz/index.php, ...)
# bleiben unberührt, weil `!-f` dann false ist und die Regel nicht
# greift. MultiViews (+MultiViews oben) resolvt zusätzlich `/foo`
# zu `/foo.php` BEVOR die Rewrites laufen, sodass Extension-lose
# Legacy-URLs weiterhin direkt funktionieren.
# ============================================================

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [L,QSA]
