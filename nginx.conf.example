# ============================================================
# intraRP – Nginx Konfiguration (Beispiel)
# ============================================================
#
# Diese Datei ist eine Referenz-Konfiguration für Nginx.
# Apache-User brauchen diese Datei NICHT – die .htaccess-Dateien
# im Projekt übernehmen dort alles automatisch.
#
# Anleitung:
#   1. Die map{}-Blöcke MÜSSEN im http{}-Block stehen
#      (nicht innerhalb von server{}!)
#   2. Den server{}-Block in deine Site-Config kopieren
#   3. Alle Stellen mit "<-- anpassen" an deine Umgebung anpassen
#   4. Testen:  sudo nginx -t
#   5. Laden:   sudo systemctl reload nginx
#
# ============================================================

# --------------------------------------------------------
# MAP-Direktiven (MÜSSEN im http{}-Block stehen,
# NICHT innerhalb von server{})
# --------------------------------------------------------

# FiveM (CitizenFX) User-Agent erkennen und CSP/X-Frame-Options
# dynamisch setzen. Ohne das zeigt FiveM nur einen weissen Bildschirm,
# weil CSP das nui:// Protokoll blockiert.
map $http_user_agent $csp_header {
    default "frame-ancestors 'self' https://*";
    ~*CitizenFX "";
}

map $http_user_agent $frame_options {
    default "SAMEORIGIN";
    ~*CitizenFX "";
}

# ============================================================
# Server-Block
# ============================================================

server {
    listen 443 ssl http2;
    server_name example.com;       # <-- anpassen

    root /var/www/intraRP;         # <-- Pfad zum Projekt-Root anpassen
    index index.php index.html;

    # SSL (Pflicht – Sessions funktionieren nur mit SSL!)
    ssl_certificate     /etc/ssl/certs/example.crt;      # <-- anpassen
    ssl_certificate_key /etc/ssl/private/example.key;     # <-- anpassen

    # ====================================================
    # Security Headers
    # ====================================================

    add_header Content-Security-Policy $csp_header always;
    add_header X-Frame-Options $frame_options always;

    # ====================================================
    # Allgemeine Einstellungen
    # ====================================================

    autoindex off;
    client_max_body_size 10M;

    # ====================================================
    # Zugriffsbeschränkungen (VOR den allgemeinen Locations)
    # ====================================================
    #
    # eNOTF-Clean-URLs (`/enotf/p/{enr}/...`) und alle anderen
    # Applikations-URLs werden vom Front-Controller über den
    # `try_files`-Fallback weiter unten dispatched.

    # Sensible Dateien komplett blockieren
    location ~ /\.(env|git|htaccess|htpasswd) {
        return 403;
    }

    # Nicht-web-Verzeichnisse — synchron zur .htaccess-Blocklist
    # (src, cli, tools, tests, database, config, docker, routes, .github)
    location ~ ^/(src|cli|tools|tests|database|config|docker|routes|\.github)/ {
        return 403;
    }

    # Zusätzlich: vendor, storage/logs, storage/cache, assets/config
    location ~ ^/(vendor|storage/logs|storage/cache|assets/config)/ {
        return 403;
    }

    # /storage/documents/ – nur PDFs erlauben
    location /storage/documents/ {
        # Alles blockieren ...
        return 403;
    }
    location ~ ^/storage/documents/.+\.pdf$ {
        # ... ausser PDFs
    }

    # /storage/profile-pictures/ – nur Bilder erlauben
    location /storage/profile-pictures/ {
        return 403;
    }
    location ~ ^/storage/profile-pictures/.+\.(png|jpe?g|webp)$ {
        # Bilder erlauben
    }

    # ====================================================
    # Request-Dispatch (Router-first)
    # ====================================================
    #
    # Fallback-Kette (Reihenfolge wichtig!):
    #   1. $uri        → existierende Datei (Assets, uploads) direkt ausliefern
    #   2. $uri/       → Directory-Index (praktisch nur noch für `public/`)
    #   3. $uri.php    → extensionlose URLs (seltener Fall — Module sind
    #                    vollständig auf den Router umgestellt, aber dieser
    #                    Schritt bleibt als Safety-Net)
    #   4. @router     → zentraler Front-Controller (public/index.php)
    #
    # Alle Applikations-URLs (`/benutzer/...`, `/enotf/...`, `/settings/...`
    # usw.) landen über den Fallback im Front-Controller, weil keine
    # physischen Modul-Verzeichnisse mehr existieren.
    #
    # Legacy `*.php`-Aufrufe (z. B. `/benutzer/list.php` aus alten Bookmarks
    # oder externen Integrationen) landen ebenfalls im Front-Controller —
    # die dort eingebaute Bridge antwortet bei GET/HEAD mit einem 301 auf
    # die Clean-URL und schreibt POST/PUT/DELETE intern um, damit Form-
    # Submits ihren Body durch die Migration retten.
    location / {
        try_files $uri $uri/ $uri.php @router;
    }

    location @router {
        rewrite ^(.*)$ /public/index.php last;
    }

    # ====================================================
    # PHP-FPM
    # ====================================================

    location ~ \.php$ {
        # Nur existierende PHP-Dateien ausführen (keine 404 an PHP weiterleiten)
        try_files $uri =404;

        # Backend-Header entfernen (damit sie nicht mit Nginx-Headern kollidieren)
        fastcgi_hide_header Content-Security-Policy;
        fastcgi_hide_header X-Frame-Options;

        fastcgi_pass unix:/run/php/php8.2-fpm.sock;   # <-- PHP-Version anpassen
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;

        # Timeout für lange Anfragen (z.B. EMD-Sync)
        fastcgi_read_timeout 120s;
    }

    # ====================================================
    # Statische Dateien – Caching
    # ====================================================

    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";

        # Header müssen in jedem Block wiederholt werden (Nginx-Verhalten)
        add_header Content-Security-Policy $csp_header always;
        add_header X-Frame-Options $frame_options always;
    }
}

# ====================================================
# HTTP → HTTPS Redirect
# ====================================================

server {
    listen 80;
    server_name example.com;       # <-- anpassen
    return 301 https://$server_name$request_uri;
}


# ============================================================
# FEHLERBEHEBUNG: FiveM zeigt weissen Bildschirm
# ============================================================
#
# Symptom:
#   Tablet (eNOTF/fireTab) in FiveM zeigt nur weiss,
#   im normalen Browser funktioniert alles.
#
# Ursache:
#   FiveM nutzt CEF (Chromium Embedded Framework) mit dem
#   User-Agent "CitizenFX". CSP-Header blockieren das
#   nui:// Protokoll, X-Frame-Options verhindert das Einbetten.
#
# Lösung (bereits in dieser Config eingebaut):
#   1. Die map-Direktiven erkennen "CitizenFX" im User-Agent
#   2. Für FiveM-Requests werden CSP + X-Frame-Options geleert
#   3. fastcgi_hide_header verhindert doppelte Header
#
# Diagnose:
#   - sudo nginx -t               → Syntax prüfen
#   - sudo systemctl reload nginx  → Config neu laden
#   - FiveM: F8-Konsole            → nach Fehlern suchen
#   - Browser: F12 → Network Tab   → Response Headers prüfen
#     → CSP sollte vorhanden sein (normaler Browser)
#     → CSP sollte LEER sein (FiveM-Request)
#
# Debug:
#   config.lua: Config.Debug = true
#   F8-Konsole öffnen, Ticket mit Logs eröffnen.
#
# WICHTIG: Sessions funktionieren nur mit SSL!
# ============================================================
