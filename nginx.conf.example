# ============================================================
# intraRP – Nginx Konfiguration (Beispiel)
# ============================================================
#
# Diese Datei ist eine Referenz-Konfiguration für Nginx.
# Apache-User brauchen diese Datei NICHT – die .htaccess-Dateien
# im Projekt übernehmen dort alles automatisch.
#
# Anleitung:
#   1. Kopiere den Inhalt in deinen server{}-Block
#      (oder inkludiere diese Datei via include)
#   2. Passe server_name, root, ssl_certificate etc. an
#   3. Teste mit: sudo nginx -t
#   4. Lade neu mit: sudo systemctl reload nginx
#
# ============================================================

# --------------------------------------------------------
# MAP-Direktiven (MÜSSEN ausserhalb von server{} stehen,
# z.B. im http{}-Block oder in einer separaten Datei)
# --------------------------------------------------------

# FiveM (CitizenFX) User-Agent erkennen und CSP/X-Frame-Options
# dynamisch setzen. Ohne das zeigt FiveM nur einen weissen Bildschirm,
# weil CSP das nui:// Protokoll blockiert.
map $http_user_agent $csp_header {
    default "frame-ancestors 'self' https://*";
    ~*CitizenFX "";
}

map $http_user_agent $frame_options {
    default "SAMEORIGIN";
    ~*CitizenFX "";
}

server {
    listen 443 ssl http2;
    server_name example.com;       # <-- anpassen

    root /var/www/intraRP;         # <-- Pfad zum Projekt-Root anpassen
    index index.php index.html;

    # SSL (Pflicht – Sessions funktionieren nur mit SSL!)
    ssl_certificate     /etc/ssl/certs/example.crt;      # <-- anpassen
    ssl_certificate_key /etc/ssl/private/example.key;     # <-- anpassen

    # ====================================================
    # Security Headers
    # ====================================================

    # CSP + X-Frame-Options dynamisch (FiveM-kompatibel)
    add_header Content-Security-Policy $csp_header always;
    add_header X-Frame-Options $frame_options always;

    # ====================================================
    # Allgemeine Einstellungen
    # ====================================================

    # Kein Directory Listing
    autoindex off;

    # Upload-Limit (für Profilbilder etc.)
    client_max_body_size 10M;

    # ====================================================
    # eNOTF Clean-URL Rewrites
    # ====================================================

    # Top-Level-Seiten (Extension entfernen)
    location ~ ^/enotf/(login|overview|create|lockscreen|loggedout|fahrzeuginfo|hospital-availability)$ {
        try_files $uri $uri/ /enotf/$1.php?$query_string;
    }

    # Protokoll: /enotf/p/{enr}
    location ~ ^/enotf/p/([\w._-]+)/?$ {
        rewrite ^/enotf/p/([\w._-]+)/?$ /enotf/protokoll/index.php?enr=$1 last;
    }

    # Protokoll: /enotf/p/{enr}/{section}
    location ~ ^/enotf/p/([\w._-]+)/([\w-]+)/?$ {
        rewrite ^/enotf/p/([\w._-]+)/([\w-]+)/?$ /enotf/protokoll/$2/index.php?enr=$1 last;
    }

    # Protokoll: /enotf/p/{enr}/{section}/{page} – Unterverzeichnisse
    location ~ ^/enotf/p/([\w._-]+)/(erstbefund|massnahmen)/([\w-]+)/?$ {
        rewrite ^/enotf/p/([\w._-]+)/(erstbefund|massnahmen)/([\w-]+)/?$ /enotf/protokoll/$2/$3/index.php?enr=$1 last;
    }

    # Protokoll: /enotf/p/{enr}/{section}/{page} – PHP-Dateien
    location ~ ^/enotf/p/([\w._-]+)/(diagnose|anamnese|rettdaten|verlauf|abschluss)/([\w_-]+)/?$ {
        rewrite ^/enotf/p/([\w._-]+)/(diagnose|anamnese|rettdaten|verlauf|abschluss)/([\w_-]+)/?$ /enotf/protokoll/$2/$3.php?enr=$1 last;
    }

    # Protokoll: /enotf/p/{enr}/{section}/{subsection}/{page} (tiefe Seiten)
    location ~ ^/enotf/p/([\w._-]+)/([\w-]+)/([\w-]+)/([\w_-]+)/?$ {
        rewrite ^/enotf/p/([\w._-]+)/([\w-]+)/([\w-]+)/([\w_-]+)/?$ /enotf/protokoll/$2/$3/$4.php?enr=$1 last;
    }

    # Print: /enotf/print/{enr}
    location ~ ^/enotf/print/([\w._-]+)/?$ {
        rewrite ^/enotf/print/([\w._-]+)/?$ /enotf/print/index.php?enr=$1 last;
    }

    # Admin: /enotf/admin → list.php
    location = /enotf/admin {
        rewrite ^ /enotf/admin/list.php last;
    }
    location = /enotf/admin/ {
        rewrite ^ /enotf/admin/list.php last;
    }

    # ====================================================
    # Extension-less PHP URLs (wie Apache MultiViews)
    # ====================================================

    location / {
        try_files $uri $uri/ $uri.php?$query_string;
    }

    # ====================================================
    # PHP-FPM
    # ====================================================

    location ~ \.php$ {
        # Backend-Header entfernen (damit sie nicht mit Nginx-Headern kollidieren)
        fastcgi_hide_header Content-Security-Policy;
        fastcgi_hide_header X-Frame-Options;

        fastcgi_pass unix:/run/php/php8.2-fpm.sock;   # <-- PHP-Version anpassen
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;

        # Timeout für lange Anfragen (z.B. EMD-Sync)
        fastcgi_read_timeout 120s;
    }

    # ====================================================
    # Zugriffsbeschränkungen
    # ====================================================

    # /tests/ – komplett blockieren
    location /tests/ {
        deny all;
        return 403;
    }

    # /storage/documents/ – nur PDFs erlauben
    location /storage/documents/ {
        location ~ \.pdf$ {
            # PDFs erlauben
        }
        location ~ (?<!\.pdf)$ {
            deny all;
            return 403;
        }
    }

    # /storage/profile-pictures/ – nur Bilder erlauben
    location /storage/profile-pictures/ {
        location ~ \.(png|jpg|jpeg|webp)$ {
            # Bilder erlauben
        }
        location ~ (?<!\.(png|jpg|jpeg|webp))$ {
            deny all;
            return 403;
        }
    }

    # Sensible Dateien blockieren
    location ~ /\.(env|git|htaccess|htpasswd) {
        deny all;
        return 403;
    }

    location ~ /(vendor|assets/config|src|storage/logs)/ {
        # PHP-Dateien in diesen Ordnern dürfen nur intern aufgerufen werden
        location ~ \.php$ {
            # Erlaubt (wird via include/require aufgerufen)
        }
        # Keine direkten Downloads von Config-Dateien etc.
        location ~ \.(json|neon|yml|yaml|xml|lock|md)$ {
            deny all;
            return 403;
        }
    }

    # ====================================================
    # Statische Dateien – Caching
    # ====================================================

    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";

        # CSP-Header auch für statische Dateien setzen (FiveM)
        add_header Content-Security-Policy $csp_header always;
        add_header X-Frame-Options $frame_options always;
    }
}

# ====================================================
# HTTP → HTTPS Redirect
# ====================================================

server {
    listen 80;
    server_name example.com;       # <-- anpassen
    return 301 https://$server_name$request_uri;
}


# ============================================================
# FEHLERBEHEBUNG: FiveM zeigt weissen Bildschirm
# ============================================================
#
# Symptom:
#   Tablet (eNOTF/fireTab) in FiveM zeigt nur weiss,
#   im normalen Browser funktioniert alles.
#
# Ursache:
#   FiveM nutzt CEF (Chromium Embedded Framework) mit dem
#   User-Agent "CitizenFX". CSP-Header blockieren das
#   nui:// Protokoll, X-Frame-Options verhindert das Einbetten.
#
# Lösung:
#   1. Die map-Direktiven oben MÜSSEN im http{}-Block stehen
#      (nicht innerhalb von server{})
#   2. add_header verwendet die Map-Variablen $csp_header
#      und $frame_options
#   3. fastcgi_hide_header entfernt Backend-Header, damit
#      sie nicht mit den Nginx-Headern kollidieren
#
# Prüfen:
#   - sudo nginx -t
#   - sudo systemctl reload nginx
#   - FiveM: F8-Konsole öffnen → nach Fehlermeldungen suchen
#   - Browser: F12 → Network → Response Headers prüfen
#     → Content-Security-Policy sollte vorhanden sein
#   - FiveM-Request: Content-Security-Policy sollte LEER sein
#
# Debug:
#   Config.Debug = true in config.lua setzen, F8-Konsole
#   öffnen, Ticket mit Logs eröffnen.
#
# WICHTIG: Sessions funktionieren nur mit SSL!
# ============================================================
